{
  "name": "purescript-wordoku",
  "description": "PureScript Wordoku",
  "version": "1.0.0",
  "author": "Nathaniel May",
  "dependencies": {
    "parcel": "^2.0.0",
    "purescript": "^0.15.16",
    "spago": "^1.0.0"
  },
  "keywords": [
    "purescript",
    "sudoku"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "license": "MIT",
  "scripts": {
    "ps-install": "spago install",
    "build": "rm -rf output && spago build --strict && parcel build index.html && cp _redirects dist/",
    "develop": "spago build && parcel index.html",
    "test": "spago test",
    "test:full": "spago test --main Test.Full",
    "bench": "spago build && node bench/main.mjs",
    "test:e2e:manual": "node test/e2e/worker_loop.spec.js",
    "format": "purs-tidy format-in-place \"src/**/*.purs\" \"test/**/*.purs\" && prettier --write .",
    "format:check": "purs-tidy check \"src/**/*.purs\" \"test/**/*.purs\" && prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nathaniel-may/purescript-wordoku"
  },
  "devDependencies": {
    "@parcel/packager-raw-url": "^2.16.4",
    "@parcel/transformer-webmanifest": "^2.16.4",
    "prettier": "^3.8.4",
    "puppeteer": "^25.1.0",
    "purs-tidy": "^0.11.1",
    "tinybench": "^6.0.2"
  }
}
